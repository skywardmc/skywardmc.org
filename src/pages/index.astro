---
import Layout from "../layouts/Layout.astro";
import IconLink from "../components/IconLink.astro";
import ProjectCard from "../components/ProjectCard.astro";
---

<Layout
	title="Home"
	description="SkywardMC is an organization that makes popular Minecraft modpacks, mods, and tools such as Adrenaline and Additive."
	style="skywardmc"
>
	<section
		class="p-4 sm:p-6 mb-4 flex flex-col items-center text-center gap-4 sm:gap-6 text-skywardmc-black bg-[url(/branding/skywardmc/background.svg)] bg-center bg-cover rounded-xs"
	>
		<img alt="SkywardMC" src="/branding/skywardmc/text-logo.svg" class="h-20" />
		<p class="font-medium">
			We're a community that makes useful Minecraft modpacks, mods, tools, and
			more.
		</p>
		<div class="flex items-center justify-center flex-wrap gap-6 font-medium">
			<IconLink
				href="https://modrinth.com/organization/skywardmc"
				icon="simple-icons:modrinth"
			>
				Modrinth
			</IconLink>
			<IconLink href="/discord" icon="simple-icons:discord"> Discord </IconLink>
			<IconLink
				href="https://matrix.to/#/#skywardmc:skywardmc.org"
				icon="simple-icons:matrix"
			>
				Matrix
			</IconLink>
			<IconLink href="https://github.com/skywardmc" icon="simple-icons:github">
				GitHub
			</IconLink>
		</div>
	</section>
	<section class="not-prose mb-4 grid grid-col md:grid-cols-2 gap-4 sm:gap-6">
		<ProjectCard
			href="/adrenaline"
			alt="Adrenaline"
			logo="/branding/adrenaline/text.svg"
			background="/branding/adrenaline/background.svg"
		>
			A lightweight, open-source performance modpack for Fabric
		</ProjectCard>
		<ProjectCard
			href="/additive"
			alt="Additive"
			logo="/branding/additive/text.svg"
			background="/branding/additive/background.svg"
		>
			A modern, open-source alternative to OptiFine for Fabric
		</ProjectCard>
		<ProjectCard
			href="/hammer"
			alt="Hammer"
			logo="/branding/hammer/text.svg"
			background="/branding/hammer/background.svg"
		>
			A lightweight, open-source performance modpack for NeoForge
		</ProjectCard>
		<ProjectCard
			href="/drill"
			alt="Drill"
			logo="/branding/drill/text.svg"
			background="/branding/drill/background.svg"
		>
			A modern, open-source alternative to OptiFine for NeoForge
		</ProjectCard>
	</section>
	<section class="prose prose-skywardmc dark:prose-invert max-w-full">
		<p>
			SkywardMC was started in 2021 by <a href="https://github.com/intergrav"
				>Devin/intergrav</a
			> (initially known as Devin's Projects), and has grown to become a larger group
			of people maintaining various different Minecraft-related things.
		</p>
		<p>
			This website was built with <a href="https://astro.build">Astro</a>,
			here's the <a href="https://github.com/skywardmc/skywardmc.org"
				>source code</a
			>. It's heavily based off Devin's personal website, <a
				href="https://devins.page">devins.page</a
			>.
		</p>
	</section>
</Layout>
