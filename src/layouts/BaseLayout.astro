---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
	title: string;
	description: string;
	style?: string;
}

const { title, description, style = "skywardmc" } = Astro.props;
const pageTitle = `${title} - SkywardMC`;
const cardImage = `/branding/${style}/card.png`;
---

<!doctype html>
<html lang="en" class="scroll-smooth md:scroll-auto" data-style={style}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<title>{pageTitle}</title>
		<meta name="description" content={description} />

		<meta name="robots" content="index, follow" />
		<meta name="author" content="SkywardMC" />

		<link rel="canonical" href={Astro.url.pathname} />
		<link
			rel="icon"
			type="image/svg+xml"
			href={`/branding/${style}/icon.svg`}
		/>
		<link rel="sitemap" href="/sitemap-index.xml" />

		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url.pathname} />
		<meta property="og:image" content={cardImage} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={cardImage} />
	</head>
	<body
		class="flex flex-col min-h-screen py-2 gap-2 text-skywardmc-offgray bg-skywardmc-offwhite dark:text-skywardmc-offwhite dark:bg-skywardmc-offgray"
	>
		<Header>
			<slot name="header-end" slot="header-end" />
		</Header>
		<main class="flex-1 w-full max-w-5xl mx-auto">
			<Nav />
			<slot />
		</main>
		<Footer />
	</body>
</html>
